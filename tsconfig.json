{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@shared/*": ["./src/shared/*"],
      "@c8c/workflow-runner": ["./packages/workflow-runner/src/index.ts"],
      "@c8c/workflow-runner/*": ["./packages/workflow-runner/src/*"],
      "@c8c/workflow-cli": ["./packages/workflow-cli/src/index.ts"],
      "@c8c/workflow-cli/*": ["./packages/workflow-cli/src/*"]
    }
  },
  "include": ["src/**/*", "packages/workflow-runner/src/**/*", "packages/workflow-cli/src/**/*"],
  "exclude": ["node_modules", "dist", "release", "out"]
}
